<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Copyright (C) 2026 SilentPulse contributors
  ~
  ~ Family Sharing Hub — Slice 1: Location Sharing screen.
  ~ Full-screen map. Toggles live in Settings → Location sharing.
  ~ Persistent bottom-sheet shows the peer list (empty in Slice 1).
  -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- The map fills the whole CoordinatorLayout. No parent ScrollView,
         so pinch/zoom and panning are handled directly by osmdroid. -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_gravity="top"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="?attr/actionBarTheme"
        app:title="@string/drawer_location_sharing" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/zoomInFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/family_zoom_in"
        app:srcCompat="@drawable/ic_add_black_24dp"
        app:fabSize="mini"
        android:tint="@color/white" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/zoomOutFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="140dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/family_zoom_out"
        app:srcCompat="@drawable/ic_remove_black_24dp"
        app:fabSize="mini"
        android:tint="@color/white" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/centerOnMeFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="220dp"
        android:contentDescription="@string/family_center_on_me"
        android:src="@android:drawable/ic_menu_mylocation"
        android:tint="@color/white"
        app:fabSize="normal" />

    <!-- Persistent bottom-sheet: peer list. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/peerSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?android:attr/windowBackground"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="170dp"
        app:behavior_hideable="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="16dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="6dp"
                android:background="?android:attr/textColorSecondary"
                android:alpha="0.4" />

            <com.silentpulse.messenger.common.widget.QkTextView
                android:id="@+id/peerSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/family_peers_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.silentpulse.messenger.common.widget.QkTextView
                android:id="@+id/peerSheetEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:gravity="center"
                android:text="@string/family_peers_empty"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/peerList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:overScrollMode="never" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
