<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- ══════════════════════════════════════════════════════
                 TOP · Enable / Disable Offline Assistant
                 ══════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/assistantEnableRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="64dp"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_assistant_black_24dp"
                        android:tint="?android:attr/textColorSecondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enable Offline Assistant"
                            android:textSize="16sp"
                            android:textColor="?android:attr/textColorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Listen for wake word and answer voice commands"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <com.silentpulse.messenger.common.widget.QkSwitch
                        android:id="@+id/assistantEnableSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════
                 CARD 2 · Speech to Text (Voice Input)
                 ══════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sttCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/assistant_section_stt"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Engine toggle: Google | Vosk -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/sttEngineToggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/sttBtnGoogle"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Google (Recommended)" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/sttBtnVosk"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vosk (Air-gapped)" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Google STT info (visible when Google selected) -->
                    <LinearLayout
                        android:id="@+id/googleSttSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Uses Android's on-device SODA recognizer (com.google.android.as). EXTRA_PREFER_OFFLINE is enabled to prevent audio from leaving the device."
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <!-- Vosk STT section (visible when Vosk selected) -->
                    <LinearLayout
                        android:id="@+id/voskSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="8dp"
                            android:text="100% air-gapped. No Google process involved."
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <!-- Download models row -->
                        <LinearLayout
                            android:id="@+id/voskDownloadRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Browse Vosk models"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Opens alphacephei.com/vosk/models — download a .zip"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Import model zip row -->
                        <LinearLayout
                            android:id="@+id/voskImportRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Import model (.zip)"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pick the downloaded .zip — copies to app storage"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Active model row -->
                        <LinearLayout
                            android:id="@+id/voskModelRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active model"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/voskModelSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="vosk-model-small-en-us-0.15" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════
                 CARD 3 · Text to Speech (Voice Output)
                 ══════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ttsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/assistant_section_tts"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Engine toggle: Google TTS | Kokoro -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/ttsEngineToggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ttsBtnAndroid"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Google TTS" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ttsBtnKokoro"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kokoro (Expressive)" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Google TTS info -->
                    <LinearLayout
                        android:id="@+id/googleTtsSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Uses Android's on-device TextToSpeech engine. No model download needed."
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <!-- Kokoro TTS section (visible when Kokoro selected) -->
                    <LinearLayout
                        android:id="@+id/kokoroSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="8dp"
                            android:text="Neural expressive TTS — fully offline via sherpa-onnx."
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <!-- Download Kokoro model row -->
                        <LinearLayout
                            android:id="@+id/kokoroDownloadRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Browse Kokoro voices"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Opens GitHub release page — download kokoro-en-v0_19.zip"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Import Kokoro model zip row -->
                        <LinearLayout
                            android:id="@+id/kokoroImportRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Import voice model (.zip)"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pick the downloaded .zip — copies to app storage"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Active voice model row -->
                        <LinearLayout
                            android:id="@+id/kokoroModelRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active voice"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/kokoroModelSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="kokoro-en-v0_19" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Speaker row -->
                        <LinearLayout
                            android:id="@+id/kokoroSpeakerRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Speaker"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/kokoroSpeakerSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="Voice 0 (default)" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Speed row -->
                        <LinearLayout
                            android:id="@+id/kokoroSpeedRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Speed"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/kokoroSpeedSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="1.0× (normal)" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════
                 CARD 4 · Voice Reply / Behavior
                 ══════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/behaviorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="4dp"
                        android:text="@string/assistant_section_behavior"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Change keyword row -->
                    <LinearLayout
                        android:id="@+id/changeKeywordRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Change trigger word"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/currentKeywordSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Current word: computer"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:alpha="0.6" />

                    </LinearLayout>

                    <!-- Voice reply row -->
                    <LinearLayout
                        android:id="@+id/voiceReplyRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_voice_reply_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_voice_reply_summary"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <com.silentpulse.messenger.common.widget.QkSwitch
                            android:id="@+id/voiceReplySwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Auto-reply timeout row -->
                    <LinearLayout
                        android:id="@+id/timeoutRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_timeout_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/timeoutSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary"
                                tools:text="30 seconds" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <!-- Voice command retry limit row -->
                    <LinearLayout
                        android:id="@+id/retryRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_retry_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/retrySummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary"
                                tools:text="2 retries" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <!-- Max announcements per message row -->
                    <LinearLayout
                        android:id="@+id/announcementsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max repeats per message"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/announcementsSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary"
                                tools:text="1 time" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy notice -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp"
                android:text="@string/settings_drive_mode_privacy"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
