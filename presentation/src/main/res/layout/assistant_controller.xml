<?xml version="1.0" encoding="utf-8"?>
<!--
 Offline Assistant screen — Material Design 3 layout.
 Sections are grouped into MaterialCardViews with generous spacing.
 All toggle preferences use MaterialSwitch; engine selection uses a
 MaterialButtonToggleGroup (inline chip-style — no dialogs for engine choice).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Collapsing toolbar ──────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back_black_24dp"
            app:title="@string/assistant_title" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable content ─────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- ══════════════════════════════════════════════════════════
                 CARD 1 · Enable Offline Assistant
                 ══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="4dp">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="4dp"
                        android:text="@string/assistant_section_enable"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Enable toggle row -->
                    <LinearLayout
                        android:id="@+id/driveModeRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="64dp"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_assistant_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/assistant_enable_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/assistant_enable_summary"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <com.silentpulse.messenger.common.widget.QkSwitch
                            android:id="@+id/driveModeSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Auto-start on Bluetooth row (shown only when enabled) -->
                    <LinearLayout
                        android:id="@+id/btAutoRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="56dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_read_sms_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                        </LinearLayout>

                        <com.silentpulse.messenger.common.widget.QkSwitch
                            android:id="@+id/readSmsSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Read all notifications row -->
                    <LinearLayout
                        android:id="@+id/readAllRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="56dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_read_all_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_read_all_summary"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <com.silentpulse.messenger.common.widget.QkSwitch
                            android:id="@+id/readAllSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════════
                 CARD 2 · Speech to Text (Voice Input)
                 ══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sttCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/assistant_section_stt"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Engine radio buttons -->
                    <RadioGroup
                        android:id="@+id/sttRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="4dp">

                        <RadioButton
                            android:id="@+id/sttRadioGoogle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="44dp"
                            android:paddingStart="4dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="@string/assistant_engine_google"
                            android:textSize="16sp"
                            android:textColor="?android:attr/textColorPrimary" />

                        <RadioButton
                            android:id="@+id/sttRadioWhisper"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="44dp"
                            android:paddingStart="4dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="@string/assistant_engine_whisper"
                            android:textSize="16sp"
                            android:textColor="?android:attr/textColorPrimary" />

                    </RadioGroup>

                    <!-- ── Google section (visible when Google selected) ─────── -->
                    <LinearLayout
                        android:id="@+id/googleSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="4dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="4dp"
                            android:paddingBottom="8dp"
                            android:text="@string/assistant_google_stt_desc"
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <LinearLayout
                            android:id="@+id/googleInstallRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="48dp"
                            android:orientation="horizontal"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/assistant_google_stt_install"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ── Whisper section (visible when Whisper selected) ───── -->
                    <LinearLayout
                        android:id="@+id/whisperSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <!-- Download models row -->
                        <LinearLayout
                            android:id="@+id/whisperDownloadRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/assistant_whisper_download"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/assistant_whisper_download_desc"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Models folder row -->
                        <LinearLayout
                            android:id="@+id/whisperFolderRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/assistant_whisper_folder_title"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/whisperFolderSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="…/files/whisper" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <!-- Active model row -->
                        <LinearLayout
                            android:id="@+id/whisperModelRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:orientation="horizontal"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/assistant_whisper_model_title"
                                    android:textSize="16sp"
                                    android:textColor="?android:attr/textColorPrimary" />

                                <TextView
                                    android:id="@+id/whisperModelSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    tools:text="Small · 488 MB" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right_black_24dp"
                                android:tint="?android:attr/textColorSecondary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════════
                 CARD 3 · Text to Speech (Voice Output)
                 ══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ttsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/assistant_section_tts"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- TTS engine row -->
                    <LinearLayout
                        android:id="@+id/ttsEngineRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_tts_engine_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/ttsEngineSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary"
                                tools:text="Android TTS (Offline)" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ══════════════════════════════════════════════════════════
                 CARD 4 · Voice Reply / Behavior
                 ══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/behaviorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="4dp"
                        android:text="@string/assistant_section_behavior"
                        android:textAllCaps="true"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Voice reply row -->
                    <LinearLayout
                        android:id="@+id/voiceReplyRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_voice_reply_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_voice_reply_summary"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary" />

                        </LinearLayout>

                        <com.silentpulse.messenger.common.widget.QkSwitch
                            android:id="@+id/voiceReplySwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Auto-reply timeout row -->
                    <LinearLayout
                        android:id="@+id/timeoutRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_drive_mode_timeout_title"
                                android:textSize="16sp"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/timeoutSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="?android:attr/textColorSecondary"
                                tools:text="30 seconds" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_black_24dp"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Privacy notice ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp"
                android:text="@string/settings_drive_mode_privacy"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
