<?xml version="1.0" encoding="utf-8"?>
<!--
  3×1 home-screen AppWidget — icons only, no text labels.

  Slot 1 (btn_notif_reader): Notification Reader toggle
  Slot 2 (btn_next_notif):   Jump to next notification
  Slot 3 (btn_voice_ast):    Voice Assistant toggle

  Icons and alpha are set dynamically in DriveModeWidgetProvider.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="4dp"
    android:background="@android:color/transparent">

    <!-- Slot 1: Notification Reader toggle -->
    <ImageButton
        android:id="@+id/btn_notif_reader"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_notifications_black_24dp"
        android:background="@android:color/transparent"
        android:contentDescription="Toggle Notification Reader"
        android:scaleType="centerInside"
        android:padding="10dp" />

    <!-- Slot 2: Next notification -->
    <ImageButton
        android:id="@+id/btn_next_notif"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_skip_next_black_24dp"
        android:background="@android:color/transparent"
        android:contentDescription="Next Notification"
        android:scaleType="centerInside"
        android:padding="10dp" />

    <!-- Slot 3: Voice Assistant toggle -->
    <ImageButton
        android:id="@+id/btn_voice_ast"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_mic_black_24dp"
        android:background="@android:color/transparent"
        android:contentDescription="Toggle Voice Assistant"
        android:scaleType="centerInside"
        android:padding="10dp" />

</LinearLayout>
