<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Family Sharing Hub — Slice 1: Location Sharing settings.
  ~ Uses the app's existing PreferenceView pattern so theming (OLED/black,
  ~ light, etc.) is automatic and consistent with the rest of Settings.
  -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:theme="?attr/actionBarTheme"
            app:title="@string/family_settings_title" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/windowBackground"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Sharing -->
            <com.silentpulse.messenger.common.widget.QkTextView
                style="@style/PreferenceCategory"
                android:text="@string/family_settings_section_sharing" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/shareToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/ic_menu_mylocation"
                app:summary="@string/family_share_my_location_hint"
                app:title="@string/family_share_my_location"
                app:widget="@layout/settings_switch_widget" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/divider" />

            <!-- Map / tiles -->
            <com.silentpulse.messenger.common.widget.QkTextView
                style="@style/PreferenceCategory"
                android:text="@string/family_settings_section_map" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/tileCacheToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_settings_black_24dp"
                app:summary="@string/family_tile_cache_hint_on"
                app:title="@string/family_tile_cache_title"
                app:widget="@layout/settings_switch_widget" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/clearTileCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_remove_black_24dp"
                app:title="@string/family_clear_tile_cache" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/divider" />

            <!-- Setup checklist -->
            <com.silentpulse.messenger.common.widget.QkTextView
                style="@style/PreferenceCategory"
                android:text="@string/family_settings_section_setup" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/setupLocationRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/ic_menu_mylocation"
                app:title="@string/family_setup_location_perm" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/setupBatteryRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_settings_black_24dp"
                app:title="@string/family_setup_battery" />

            <com.silentpulse.messenger.common.widget.PreferenceView
                android:id="@+id/setupOemRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:icon="@drawable/ic_settings_black_24dp"
                app:title="@string/family_setup_oem_autostart" />

            <com.silentpulse.messenger.common.widget.QkTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_horizontal"
                android:text="@string/family_attribution"
                android:textSize="11sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
